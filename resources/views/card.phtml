<?php

declare(strict_types=1);

namespace TreesListModule;

use Fisharebest\Webtrees\Http\RequestHandlers\TreePage;
use Fisharebest\Webtrees\I18N;
use TreesListModule\MoreI18N;

?>
<div class="family-trees-list">
    <?php if ($all_trees === []) : ?>
        <div class="family-trees-list__empty"><?= I18N::translate('No family trees can be shown.') ?></div>
    <?php endif ?>

    <div class="family-trees-list__grid">
        <?php foreach ($all_trees as $tree) : ?>
            <?php
            $tree_id = $tree->id();
            $stats = [];
            foreach ([
                'families' => [$familyicon, MoreI18N::xlate('Families'), $families],
                'individuals' => [$individualicon, MoreI18N::xlate('Individuals'), $individuals],
                'events' => [$eventicon, MoreI18N::xlate('Events'), $events],
                'surnames' => [$surnameicon, MoreI18N::xlate('Surnames'), $surnames],
            ] as $key => [$icon, $label, $values]) {
                if (isset($visible_fields[$key])) {
                    $stats[] = ['icon' => $icon, 'label' => $label, 'value' => (int) ($values[$tree_id] ?? 0)];
                }
            }
            ?>
            <article class="family-trees-list__card">
                <a class="family-trees-list__title" href="<?= e(route(TreePage::class, ['tree' => $tree->name()])) ?>">
                    <img src="<?= e($treeicon) ?>" alt="">
                    <?= e($tree->title()) ?>
                </a>
                <?php if (isset($visible_fields['purpose']) && ($purposes[$tree_id] ?? '') !== '') : ?>
                    <div class="family-trees-list__purpose"><?= e($purposes[$tree_id]) ?></div>
                <?php endif ?>
                <div class="family-trees-list__stats">
                    <?php foreach ($stats as $stat) : ?>
                        <span class="family-trees-list__stat">
                            <span class="family-trees-list__stat-label"><img src="<?= e($stat['icon']) ?>" alt=""> <?= e($stat['label']) ?></span>
                            <span class="family-trees-list__stat-value"><?= I18N::number($stat['value']) ?></span>
                        </span>
                    <?php endforeach ?>
                </div>
            </article>
        <?php endforeach ?>
    </div>
</div>
