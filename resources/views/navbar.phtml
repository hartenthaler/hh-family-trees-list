<?php

declare(strict_types=1);

namespace TreesListModule;

use Fisharebest\Webtrees\Http\RequestHandlers\TreePage;
use Fisharebest\Webtrees\I18N;
use TreesListModule\MoreI18N;

?>
<div class="family-trees-list">
    <?php if ($all_trees === []) : ?>
        <div class="family-trees-list__empty"><?= I18N::translate('No family trees can be shown.') ?></div>
    <?php endif ?>

    <?php foreach ($all_trees as $tree) : ?>
        <?php
        $tree_id = $tree->id();
        $stats = [];
        foreach ([
            'families' => [MoreI18N::xlate('Families'), $families],
            'individuals' => [MoreI18N::xlate('Individuals'), $individuals],
            'events' => [MoreI18N::xlate('Events'), $events],
            'surnames' => [MoreI18N::xlate('Surnames'), $surnames],
        ] as $key => [$label, $values]) {
            if (isset($visible_fields[$key])) {
                $stats[] = ['label' => $label, 'value' => (int) ($values[$tree_id] ?? 0)];
            }
        }
        ?>
        <div class="family-trees-list__navbar-row">
            <a class="family-trees-list__navbar-title" href="<?= e(route(TreePage::class, ['tree' => $tree->name()])) ?>">
                <strong><?= e($tree->title()) ?></strong>
            </a>
            <?php if (isset($visible_fields['purpose']) && ($purposes[$tree_id] ?? '') !== '') : ?>
                <span class="family-trees-list__navbar-purpose"><?= e($purposes[$tree_id]) ?></span>
            <?php endif ?>
            <?php foreach ($stats as $stat) : ?>
                <span class="family-trees-list__navbar-stat" title="<?= e($stat['label']) ?>">
                    <?= I18N::number($stat['value']) ?>
                </span>
            <?php endforeach ?>
        </div>
    <?php endforeach ?>
</div>
