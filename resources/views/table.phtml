<?php

declare(strict_types=1);

use Fisharebest\Webtrees\Http\RequestHandlers\TreePage;
use Fisharebest\Webtrees\I18N;
use Hartenthaler\Webtrees\Module\FamilyTreesList\Internationalization\MoreI18N;

?>
<div class="family-trees-list">
    <?php if ($all_trees === []) : ?>
        <div class="family-trees-list__empty"><?= I18N::translate('No family trees can be shown.') ?></div>
    <?php else : ?>
        <?php $table_id = 'family-trees-list-table-' . (int) $block_id; ?>
        <div class="table-responsive">
            <table id="<?= e($table_id) ?>" class="table table-sm table-striped family-trees-list__table">
                <thead>
                    <tr>
                        <th>
                            <button class="family-trees-list__sort-button" type="button" data-family-trees-list-sort="0">
                                <img class="family-trees-list__table-icon" src="<?= e($treeicon) ?>" alt="">
                                <?= MoreI18N::xlate('Family tree') ?>
                            </button>
                        </th>
                        <?php
                        $columns = [];
                        if (isset($visible_fields['purpose'])) {
                            $columns[] = ['key' => 'purpose', 'icon' => null, 'label' => I18N::translate('Research purpose')];
                        }
                        foreach ([
                            'families' => [$familyicon, MoreI18N::xlate('Families')],
                            'individuals' => [$individualicon, MoreI18N::xlate('Individuals')],
                            'events' => [$eventicon, MoreI18N::xlate('Events')],
                            'surnames' => [$surnameicon, MoreI18N::xlate('Surnames')],
                        ] as $key => [$icon, $label]) {
                            if (isset($visible_fields[$key])) {
                                $columns[] = ['key' => $key, 'icon' => $icon, 'label' => $label];
                            }
                        }
                        ?>
                        <?php foreach ($columns as $index => $column) : ?>
                            <th>
                                <button class="family-trees-list__sort-button" type="button" data-family-trees-list-sort="<?= $index + 1 ?>">
                                    <?php if ($column['icon'] !== null) : ?>
                                        <img class="family-trees-list__table-icon" src="<?= e($column['icon']) ?>" alt="">
                                    <?php endif ?>
                                    <?= e($column['label']) ?>
                                </button>
                            </th>
                        <?php endforeach ?>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($all_trees as $tree) : ?>
                        <?php $tree_id = $tree->id(); ?>
                        <tr>
                            <td data-sort="<?= e($tree->title()) ?>">
                                <a href="<?= e(route(TreePage::class, ['tree' => $tree->name()])) ?>">
                                    <strong><?= e($tree->title()) ?></strong>
                                </a>
                            </td>
                            <?php foreach ($columns as $column) : ?>
                                <?php if ($column['key'] === 'purpose') : ?>
                                    <td data-sort="<?= e($purposes[$tree_id] ?? '') ?>"><?= e($purposes[$tree_id] ?? '') ?></td>
                                <?php else : ?>
                                    <?php $values = ${$column['key']}; ?>
                                    <td data-sort="<?= (int) ($values[$tree_id] ?? 0) ?>"><?= I18N::number((int) ($values[$tree_id] ?? 0)) ?></td>
                                <?php endif ?>
                            <?php endforeach ?>
                        </tr>
                    <?php endforeach ?>
                </tbody>
            </table>
        </div>
        <div class="family-trees-list__hint"><?= I18N::translate('*Click on the header to sort the values.') ?></div>
        <script>
        document.querySelectorAll('#<?= e($table_id) ?> [data-family-trees-list-sort]').forEach(function (button) {
            button.addEventListener('click', function () {
                var table = document.getElementById('<?= e($table_id) ?>');
                var column = parseInt(button.getAttribute('data-family-trees-list-sort'), 10);
                var tbody = table.querySelector('tbody');
                var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
                var current = button.getAttribute('data-sort-direction') || 'asc';
                var next = current === 'asc' ? 'desc' : 'asc';

                rows.sort(function (left, right) {
                    var leftValue = left.children[column].getAttribute('data-sort') || left.children[column].textContent;
                    var rightValue = right.children[column].getAttribute('data-sort') || right.children[column].textContent;
                    var leftNumber = Number(leftValue);
                    var rightNumber = Number(rightValue);
                    var result;

                    if (!Number.isNaN(leftNumber) && !Number.isNaN(rightNumber)) {
                        result = leftNumber - rightNumber;
                    } else {
                        result = leftValue.localeCompare(rightValue);
                    }

                    return next === 'asc' ? result : -result;
                });

                table.querySelectorAll('[data-family-trees-list-sort]').forEach(function (otherButton) {
                    otherButton.removeAttribute('data-sort-direction');
                });
                button.setAttribute('data-sort-direction', next);
                rows.forEach(function (row) {
                    tbody.appendChild(row);
                });
            });
        });
        </script>
    <?php endif ?>
</div>
